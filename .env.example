# Arquivo de variaveis de ambiente usado como exemplo para configurar a stack.
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.
REGISTRATION_ENV_FILE=./.env.example

# Ambiente de execucao das aplicacoes .NET.
# Em desenvolvimento local, normalmente use Development.
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production

# Configuracao do MongoDB usado pelo servico de registro.
# ConnectionString aponta para o container/host do MongoDB.
# MasterDatabaseName define o banco mestre compartilhado da plataforma.
Mongo__ConnectionString=mongodb://mongo:27017
Mongo__MasterDatabaseName=SaasMasterDb

# Chave usada para assinar tokens JWT. Use um valor forte e secreto em producao.
Jwt__SigningKey=123456789123456789123456789123456

# Chave usada para criptografar chaves de assinatura dos tenants.
# Deve ser forte, secreta e estavel; trocar este valor pode invalidar dados criptografados.
Security__TenantSigningKeyEncryptionKey=123456789123456789123456789123456

# Chave de acesso da API de provisionamento master.
# Use um valor secreto e diferente para cada ambiente.
Master__ProvisioningApiKey=123456789

# SMTP master, usado por fluxos administrativos/globais.
# Defina UseSmtp=true para enviar e-mails via servidor SMTP real.
MasterSmtp__UseSmtp=true
MasterSmtp__Host=smtp.gmail.com
MasterSmtp__Port=587
MasterSmtp__Usuario=contato.asfsolutions@gmail.com
MasterSmtp__Senha=zurq wvwq rckk xvom
MasterSmtp__EmailRemetente=contato.asfsolutions@gmail.com
MasterSmtp__NomeRemetente=Lightcode
MasterSmtp__UsarSsl=true

# RabbitMQ usado para mensageria e processamento assincrono.
# HostName deve corresponder ao nome do container/host acessivel pela aplicacao.
RabbitMQ__HostName=rabbitmq
RabbitMQ__Port=5672
RabbitMQ__UserName=guest
RabbitMQ__Password=guest
RabbitMQ__VirtualHost=/

# Intervalo, em minutos, para rotinas periodicas de varredura/processamento.
RabbitMQ__ScanIntervalMinutes=60

# URL publica base da API de registro.
Registration__PublicApiBaseUrl=http://localhost:3000

# Origens permitidas para chamadas CORS.
# Adicione novas origens incrementando o indice: Cors__AllowedOrigins__2, etc.
Cors__AllowedOrigins__0=http://localhost:8080
Cors__AllowedOrigins__1=http://localhost:5173

# SMTP padrao aplicado a novos tenants quando eles nao possuem configuracao propria.
# Em producao, nao mantenha credenciais reais neste arquivo de exemplo.
TenantDefaultSmtp__Host=smtp.gmail.com
TenantDefaultSmtp__Port=587
TenantDefaultSmtp__Usuario=contato.asfsolutions@gmail.com
TenantDefaultSmtp__Senha=zurq wvwq rckk xvom
TenantDefaultSmtp__EmailRemetente=contato.asfsolutions@gmail.com
TenantDefaultSmtp__NomeRemetente=Lightcode
TenantDefaultSmtp__UsarSsl='true'

# SMTP geral da aplicacao.
# Configure quando o servico precisar enviar e-mails diretamente.
Smtp__UseSmtp=true
