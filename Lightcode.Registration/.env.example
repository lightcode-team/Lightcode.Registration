# Copie para .env e ajuste em desenvolvimento local (dotnet run).
# Em Docker, o compose usa este ficheiro via env_file e sobrescreve hosts (mongo, rabbitmq).

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5012

Mongo__ConnectionString=mongodb://127.0.0.1:27017
Mongo__MasterDatabaseName=SaasMasterDb

# Mínimo 32 caracteres
Jwt__SigningKey=123456789123456789123456789123456

Master__ProvisioningApiKey=123456789
