@model Lightcode.Registration.Models.ResetPasswordViewModel
@{
    var frontConfig = Model.FrontConfig;
    var backgroundStyle = string.IsNullOrWhiteSpace(frontConfig.BackgroundImageUrl)
        ? null
        : $"--login-background-image: url('{frontConfig.BackgroundImageUrl}');";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@frontConfig.Messages.ResetPasswordHeading</title>
    <style>@Html.Raw(frontConfig.Css)</style>
</head>
<body style="@backgroundStyle">
    <main class="login-card" aria-labelledby="reset-title">
        <partial name="~/Views/Shared/_AuthLogo.cshtml" model="frontConfig" />
        <h1 id="reset-title" class="login-title">@frontConfig.Messages.ResetPasswordHeading</h1>

        @if (Model.IsCompleted)
        {
            <p class="login-subtitle">Sua senha foi atualizada.</p>
            <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
            @if (!string.IsNullOrWhiteSpace(Model.TransactionId))
            {
                <a class="auth-link auth-link-centered" href="/auth/login?transactionId=@Uri.EscapeDataString(Model.TransactionId)">Voltar ao login</a>
            }
        }
        else
        {
            <p class="login-subtitle">@frontConfig.Messages.ResetPasswordSubtitle</p>
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert" role="alert">@Model.ErrorMessage</div>
            }

            <form method="post" action="/reset-password" data-login-form>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="TenantId" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="TransactionId" />
                <div class="field">
                    <label asp-for="NewPassword"></label>
                    <input asp-for="NewPassword" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="field-error"></span>
                </div>
                <div class="field">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
                <button type="submit" class="login-submit" data-login-submit data-loading-text="Redefinindo...">Redefinir senha</button>
            </form>
        }
    </main>
    <script src="~/auth/js/login.js" asp-append-version="true"></script>
</body>
</html>
