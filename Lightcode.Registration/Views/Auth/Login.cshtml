@model Lightcode.Registration.Models.LoginViewModel
@{
    var frontConfig = Model.FrontConfig;
    var messages = frontConfig.Messages;
    var backgroundStyle = string.IsNullOrWhiteSpace(frontConfig.BackgroundImageUrl)
        ? null
        : $"--login-background-image: url('{frontConfig.BackgroundImageUrl}');";
}
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@messages.PageTitle</title>
    <style>
        @Html.Raw(frontConfig.Css)
    </style>
</head>
<body style="@backgroundStyle">
    <main class="login-card" aria-labelledby="login-title">
        <partial name="~/Views/Shared/_AuthLogo.cshtml" model="frontConfig" />

        <h1 id="login-title" class="login-title">@messages.Heading</h1>
        <p class="login-subtitle">@messages.Subtitle</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.TransactionId))
        {
        <form method="post" action="/auth/login" data-login-form>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TransactionId" />
            <input type="hidden" asp-for="TenantId" />

            <div class="field">
                <label for="Username">@messages.UsernameLabel</label>
                <input asp-for="Username" autocomplete="username" placeholder="@messages.UsernamePlaceholder" data-login-username autofocus />
                <span asp-validation-for="Username" class="field-error"></span>
            </div>

            <div class="field">
                <label for="Password">@messages.PasswordLabel</label>
                <div class="password-field">
                    <input asp-for="Password" autocomplete="current-password" placeholder="@messages.PasswordPlaceholder" data-password-input />
                    <button type="button" class="password-toggle" data-password-toggle aria-label="Mostrar ou ocultar senha">Mostrar</button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <a class="auth-link auth-link-right" href="/auth/forgot-password?transactionId=@Uri.EscapeDataString(Model.TransactionId)">Esqueci minha senha</a>

            <button type="submit" class="login-submit" data-login-submit data-loading-text="@messages.SubmittingButton">
                @messages.SubmitButton
            </button>
        </form>
        }
    </main>
    <script src="~/auth/js/login.js" asp-append-version="true"></script>
</body>
</html>
