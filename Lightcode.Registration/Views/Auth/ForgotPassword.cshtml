@model Lightcode.Registration.Models.ForgotPasswordViewModel
@{
    var frontConfig = Model.FrontConfig;
    var backgroundStyle = string.IsNullOrWhiteSpace(frontConfig.BackgroundImageUrl)
        ? null
        : $"--login-background-image: url('{frontConfig.BackgroundImageUrl}');";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@frontConfig.Messages.ForgotPasswordHeading</title>
    <style>@Html.Raw(frontConfig.Css)</style>
</head>
<body style="@backgroundStyle">
    <main class="login-card" aria-labelledby="forgot-title">
        <partial name="~/Views/Shared/_AuthLogo.cshtml" model="frontConfig" />
        <h1 id="forgot-title" class="login-title">@frontConfig.Messages.ForgotPasswordHeading</h1>
        <p class="login-subtitle">@frontConfig.Messages.ForgotPasswordSubtitle</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert" role="alert">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
        }

        <form method="post" action="/auth/forgot-password" data-login-form>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TransactionId" />
            <div class="field">
                <label asp-for="Identifier">Username ou e-mail</label>
                <input asp-for="Identifier" autocomplete="username" data-login-username autofocus />
                <span asp-validation-for="Identifier" class="field-error"></span>
            </div>
            <button type="submit" class="login-submit" data-login-submit data-loading-text="Enviando...">Enviar instruções</button>
        </form>
        <a class="auth-link auth-link-centered" href="/auth/login?transactionId=@Uri.EscapeDataString(Model.TransactionId)">Voltar ao login</a>
    </main>
    <script src="~/auth/js/login.js" asp-append-version="true"></script>
</body>
</html>
