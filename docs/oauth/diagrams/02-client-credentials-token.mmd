sequenceDiagram
    autonumber
    participant Client as App Cliente
    participant Token as POST /api/auth/token
    participant Auth as AuthenticationAppService
    participant TenantLookup as ITenantLookup
    participant OAuthRepo as IOAuthClientRepository
    participant Keys as ITenantSigningKeyResolver
    participant Issuer as JwtAccessTokenIssuer
    participant Refresh as IRefreshTokenRepository
    participant TenantDb as tenant_{id}

    Client->>Token: grant_type=client_credentials + X-Tenant-Id
    Token->>Auth: IssueTokenAsync(request, tenantId)
    Auth->>TenantLookup: FindActiveByIdAsync(tenantId)
    TenantLookup-->>Auth: Tenant ativo
    Auth->>OAuthRepo: FindByClientIdAsync(tenantId, client_id)
    OAuthRepo-->>Auth: OAuthClient ativo
    Auth->>Auth: Verificar client_secret contra hash PBKDF2
    Auth->>Auth: TokenIssuanceProfile.FromOAuthClient
    Auth->>Keys: ResolveSigningKeyAsync(tenantId)
    Keys-->>Auth: Privaté key RS256 do tenant
    Auth->>Issuer: CreateAccessToken(subject=client_id)
    Issuer-->>Auth: access_token JWT
    Auth->>Refresh: CreateAsync(subjectType=client)
    Refresh->>TenantDb: Inserir RefreshToken com TokenHash
    Refresh-->>Auth: refresh_token puro
    Auth-->>Client: requires_2fa=false + access_token + refresh_token
