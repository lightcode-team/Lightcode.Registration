%%{init: {"theme":"base","securityLevel":"strict","deterministicIds":true,"deterministicIDSeed":"liguthub-docs","themeVariables":{"fontFamily":"Inter, ui-sans-serif, system-ui","fontSize":"15px","background":"#ffffff","primaryColor":"#f8fafc","primaryTextColor":"#0f172a","primaryBorderColor":"#cbd5e1","secondaryColor":"#eff6ff","secondaryTextColor":"#1e3a8a","secondaryBorderColor":"#93c5fd","tertiaryColor":"#ecfdf5","tertiaryTextColor":"#065f46","tertiaryBorderColor":"#86efac","lineColor":"#64748b","textColor":"#0f172a"}}}%%
flowchart TD
    A[Requisição humana de autenticação] --> B{Endpoint}

    B --> C[POST /api/auth/token password]
    C --> C1[Chave: IP + tenant + username/e-mail]
    C1 --> C2[Limite: 10 por minuto]

    B --> D[POST /api/platform-auth/token]
    D --> D1[Chave: IP + e-mail]
    D1 --> D2[Limite: 10 por minuto]

    B --> E[POST /api/auth/confirm-2fa]
    E --> E1[Chave: IP + tenant + challenge_id]
    E1 --> E2[Limite: 5 por 5 minutos]

    B --> F[POST /api/platform-auth/confirm-2fa]
    F --> F1[Chave: IP + challenge_id]
    F1 --> F2[Limite: 5 por 5 minutos]

    B --> G[Endpoints /me/2fa]
    G --> G1[Chave: IP + tenant ou master + subject]
    G1 --> G2[Limite begin: 5 por 10 minutos]
    G1 --> G3[Limite confirm: IP + challenge_id]

    B --> H[Recovery e confirmação de e-mail]
    H --> H1[Chave: IP + tenant + e-mail/username]
    H1 --> H2[Limite: 5 por 10 minutos]

    C2 --> I{Permitido?}
    D2 --> I
    E2 --> I
    F2 --> I
    G2 --> I
    G3 --> I
    H2 --> I

    I -->|Sim| J[Continuar fluxo normal]
    I -->|Não| K[HTTP 429 genérico]
    K --> L[Log sanitizado sem senha, código, token, cookie ou body completo]

    M[grant_type=client_credentials] --> N[Não usa política de login humano]

    classDef endpoint fill:#eff6ff,stroke:#93c5fd,color:#1e3a8a;
    classDef limit fill:#ecfdf5,stroke:#86efac,color:#065f46;
    class C,D,E,F,G,H,M endpoint;
    class C1,C2,D1,D2,E1,E2,F1,F2,G1,G2,G3,H1,H2,N limit;
