meta {
  name: Delete Email Template
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/api/email-templates/{{emailTemplateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

docs {
  **DELETE** `/api/email-templates/{id}` — requer role `template-write` ou scope `email-admin`.
}
