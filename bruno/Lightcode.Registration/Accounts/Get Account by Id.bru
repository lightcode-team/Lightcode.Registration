  name: Get Account by Id (admin)
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/accounts/{{userId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

vars:pre-request {
  userId: 6a27854a98500353908dfc50
}

docs {
  # Obter conta por id (admin)
  
  **GET** `/api/accounts/{userId}`
  
  Requer JWT com role `admin` ou scope `owner`.
  Devolve `profile` sem password nem segredos de confirmação de email.
}
